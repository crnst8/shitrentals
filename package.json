{
  "name": "shitrentals",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "crnst8",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server/app.js",
    "dev:web": "vite",
    "start": "node server/app.js",
    "build": "vite build",
    "sync": "node scripts/sync-airtable.mjs",
    "reseed": "node scripts/reseed.mjs",
    "cross-reference": "node scripts/cross-reference-rentals.mjs",
    "cross-reference:update": "node scripts/cross-reference-rentals.mjs --incremental",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint .",
    "verify": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.10.1",
    "hono": "^4.12.25",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "csv-parse": "^6.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.12"
  }
}
