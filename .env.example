# Copy to .env (gitignored) and adjust. None of these are secrets — the app and
# data scripts need no credentials. These are deployment overrides only.

# --- API (VPS / container) ---
# Port the Hono server listens on.
PORT=3001
# Where the SQLite DB lives. On Docker this is the mounted volume.
DB_PATH=/data/shitrentals.db
# Browser origin(s) allowed to call the API cross-site, comma-separated.
# Set this to your Cloudflare Pages URL(s) when the frontend is hosted there.
# Leave empty when the same Node process serves the built frontend.
CORS_ORIGIN=https://shitrentals.pages.dev

# --- Frontend (Cloudflare Pages build) ---
# Absolute URL of the API. Set in the Pages project's build env vars, NOT here.
# Leave unset for single-origin deploys (Node serves dist/ + /api together).
# VITE_API_BASE=https://api.shitrentals.example
